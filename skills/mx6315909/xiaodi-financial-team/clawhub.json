{
  "name": "xiaodi-financial-team",
  "version": "2.1.0",
  "description": "小弟金融分析师团队，6 个专业分析师协作完成股票/基金深度分析。支持快速/标准/专业三档报告，分析师之间自动迭代优化。",
  "author": "xiaodi <mxbot-xiaodi@agentmail.to>",
  "license": "MIT",
  "category": "Finance",
  "tags": ["finance", "stock", "fund", "analysis", "multi-agent", "china", "a-share", "xiaodi"],
  "pricing": {
    "type": "free"
  },
  "features": [
    "6 个专业分析师协作（产业/估值/技术/风险/资金/策略）",
    "股票 + 基金双覆盖（A 股/港股/美股/各类基金）",
    "三档报告（快速版~1 分钟/标准版~5 分钟/专业版~15 分钟）",
    "分析师自动迭代优化机制",
    "自动适配 AI 模型（GLM-5/Qwen/Kimi/GPT 等）",
    "智能安装脚本，一键配置环境",
    "三种运行模式（完整/标准/纯AI）"
  ],
  "useCases": [
    "个股深度诊断",
    "基金推荐与分析",
    "持仓复盘与调仓建议",
    "投资决策支持",
    "市场趋势分析"
  ],
  "requirements": {
    "openclaw": ">=1.0.0",
    "python": ">=3.9",
    "env": ["ZHIPU_API_KEY", "BROWSERLESS_URL", "BROWSERLESS_API_KEY"],
    "files": ["~/.openclaw/openclaw.json"],
    "externalApis": [
      "https://open.bigmodel.cn/api/paas/v4",
      "https://push2.eastmoney.com",
      "https://quote.eastmoney.com"
    ]
  },
  "optionalDependencies": {
    "akshare": {
      "version": ">=1.10.0",
      "purpose": "实时行情、财务数据",
      "installCommand": "pip install akshare"
    },
    "browserless": {
      "purpose": "PE/PB 财务数据",
      "installCommand": "docker run -d -p 3000:3000 browserless/chrome"
    }
  },
  "installScript": "install.sh",
  "postInstallMessage": "运行 ./install.sh 配置环境依赖",
  "repository": {
    "type": "git",
    "url": "https://github.com/mx6315909/obsidian-vault",
    "directory": "skills/financial-analyst-team"
  },
  "keywords": [
    "股票分析",
    "基金推荐",
    "金融分析",
    "持仓复盘",
    "多 Agent 协作",
    "A 股",
    "投资决策"
  ]
}
