{
  "version": "1.0",
  "categories": {
    "personality": "性格参数，反思时锁定不变",
    "tactical": "战术参数，允许反思调整"
  },
  "params": {
    "trend_weight":        { "type": "float", "min": 0, "max": 1, "default": 0.30, "category": "personality", "group": "signal_weight", "description": "趋势信号权重" },
    "momentum_weight":     { "type": "float", "min": 0, "max": 1, "default": 0.25, "category": "personality", "group": "signal_weight", "description": "动量信号权重" },
    "mean_revert_weight":  { "type": "float", "min": 0, "max": 1, "default": 0.15, "category": "personality", "group": "signal_weight", "description": "均值回归信号权重" },
    "volume_weight":       { "type": "float", "min": 0, "max": 1, "default": 0.15, "category": "personality", "group": "signal_weight", "description": "量能信号权重" },
    "volatility_weight":   { "type": "float", "min": 0, "max": 1, "default": 0.15, "category": "personality", "group": "signal_weight", "description": "波动率信号权重" },

    "entry_threshold":     { "type": "float", "min": 0.05, "max": 0.55, "default": 0.20, "category": "tactical", "description": "入场阈值，越高越保守" },
    "exit_threshold":      { "type": "float", "min": 0.05, "max": 0.40, "default": 0.10, "category": "tactical", "description": "出场阈值" },

    "long_bias":           { "type": "float", "min": 0, "max": 1, "default": 0.50, "category": "personality", "description": "方向偏好: 0=只做空, 0.5=双向, 1=只做多" },

    "fast_ma_period":      { "type": "int", "min": 3, "max": 50, "default": 10, "category": "tactical", "description": "快速均线周期" },
    "slow_ma_period":      { "type": "int", "min": 20, "max": 200, "default": 50, "category": "tactical", "description": "慢速均线周期" },
    "trend_strength_min":  { "type": "float", "min": 10, "max": 50, "default": 25, "category": "tactical", "description": "ADX趋势强度阈值" },
    "supertrend_mult":     { "type": "float", "min": 1, "max": 5, "default": 3.0, "category": "tactical", "description": "超级趋势乘数" },

    "rsi_period":          { "type": "int", "min": 5, "max": 30, "default": 14, "category": "tactical", "description": "RSI周期" },
    "rsi_overbought":      { "type": "float", "min": 60, "max": 90, "default": 70, "category": "tactical", "description": "RSI超买阈值" },
    "rsi_oversold":        { "type": "float", "min": 10, "max": 40, "default": 30, "category": "tactical", "description": "RSI超卖阈值" },
    "macd_fast":           { "type": "int", "min": 5, "max": 20, "default": 12, "category": "tactical", "description": "MACD快线周期" },
    "macd_slow":           { "type": "int", "min": 15, "max": 40, "default": 26, "category": "tactical", "description": "MACD慢线周期" },
    "macd_signal":         { "type": "int", "min": 5, "max": 15, "default": 9, "category": "tactical", "description": "MACD信号线周期" },

    "bb_period":           { "type": "int", "min": 10, "max": 50, "default": 20, "category": "tactical", "description": "布林带周期" },
    "bb_std":              { "type": "float", "min": 1, "max": 4, "default": 2.0, "category": "tactical", "description": "布林带标准差倍数" },

    "base_leverage":       { "type": "float", "min": 1, "max": 150, "default": 10, "category": "personality", "description": "基础杠杆倍数" },
    "max_leverage":        { "type": "float", "min": 1, "max": 150, "default": 100, "category": "personality", "description": "最大杠杆倍数" },
    "risk_per_trade":      { "type": "float", "min": 0.01, "max": 0.50, "default": 0.10, "category": "personality", "description": "每笔风险比例" },
    "max_position_pct":    { "type": "float", "min": 0.05, "max": 1.0, "default": 0.50, "category": "personality", "description": "单笔最大仓位占比" },

    "sl_atr_mult":         { "type": "float", "min": 0.5, "max": 5.0, "default": 2.0, "category": "tactical", "description": "止损ATR倍数" },
    "tp_rr_ratio":         { "type": "float", "min": 1.0, "max": 10.0, "default": 3.0, "category": "tactical", "description": "止盈风险回报比" },
    "trailing_enabled":    { "type": "bool", "default": false, "category": "tactical", "description": "是否启用移动止损" },
    "trailing_activation_pct": { "type": "float", "min": 0.01, "max": 0.20, "default": 0.02, "category": "tactical", "description": "移动止损激活阈值" },
    "trailing_distance_atr":   { "type": "float", "min": 0.5, "max": 5.0, "default": 1.5, "category": "tactical", "description": "移动止损距高点ATR倍数" },

    "rolling_enabled":     { "type": "bool", "default": false, "category": "personality", "description": "是否启用滚仓" },
    "rolling_trigger_pct": { "type": "float", "min": 0.10, "max": 1.0, "default": 0.30, "category": "personality", "description": "滚仓触发浮盈比例" },
    "rolling_reinvest_pct":{ "type": "float", "min": 0.10, "max": 1.0, "default": 0.80, "category": "personality", "description": "滚仓再投入比例" },
    "rolling_max_times":   { "type": "int", "min": 1, "max": 10, "default": 3, "category": "personality", "description": "最大滚仓次数" },
    "rolling_move_stop":   { "type": "bool", "default": true, "category": "personality", "description": "滚仓后是否移动老仓止损到成本价" },

    "regime_sensitivity":  { "type": "float", "min": 0, "max": 1, "default": 0.50, "category": "tactical", "description": "行情敏感度: 0=忽略, 1=严格跟随" },
    "exit_on_regime_change": { "type": "bool", "default": true, "category": "tactical", "description": "行情切换时是否平仓" }
  },
  "signals": {
    "trend":       { "weight_param": "trend_weight",       "module": "core.decision" },
    "momentum":    { "weight_param": "momentum_weight",    "module": "core.decision" },
    "mean_revert": { "weight_param": "mean_revert_weight", "module": "core.decision" },
    "volume":      { "weight_param": "volume_weight",      "module": "core.decision" },
    "volatility":  { "weight_param": "volatility_weight",  "module": "core.decision" }
  },
  "constraints": {
    "signal_weight_sum": "group:signal_weight 的参数之和应接近 1.0",
    "leverage_range": "base_leverage 和 max_leverage 在 1-150 之间",
    "slow_gt_fast": "slow_ma_period > fast_ma_period"
  }
}
