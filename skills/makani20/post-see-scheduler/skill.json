{
  "name": "post-see-post-scheduling-skill",
  "description": "Turn your OpenClaw into an autonomous social media manager using the Post See API. Use when scheduling, posting, or managing content across Instagram, LinkedIn, X, Facebook, Threads, Bluesky, Pinterest, YouTube, Mastodon, Discord, and other networks Post See supports.",
  "entry": "prompts/generate-post.txt",
  "version": "1.1.0",
  "documentation": "https://api.post-see.com/",
  "openapi": "https://api.post-see.com/openapi.yaml",
  "product": "https://post-see.com",
  "runtime": {
    "node": ">=18"
  },
  "environment": {
    "required": ["POST_SEE_API_KEY"],
    "optional": ["POST_SEE_WORKSPACE_ID", "POST_SEE_TIMEZONE"],
    "primary": "POST_SEE_API_KEY"
  },
  "bins": {
    "optional": ["ffmpeg"]
  },
  "prompts": {
    "schedule": "prompts/schedule-post.txt"
  },
  "actions": [
    "actions/bluesky.js",
    "actions/discord.js",
    "actions/facebook.js",
    "actions/instagram.js",
    "actions/linkedin.js",
    "actions/mastodon.js",
    "actions/pinterest.js",
    "actions/threads.js",
    "actions/x.js",
    "actions/youtube.js"
  ],
  "actions_shared": ["actions/post-see-client.js"]
}
