{
  "name": "movie-butler",
  "displayName": "🎬 观影小管家",
  "version": "1.0.0",
  "description": "杜老师的专属观影助手，整合 TMDB + Emby，提供电影查询、媒体库管理、个性化推荐、每周观影计划等服务",
  "author": "小暖阳",
  "license": "MIT",
  "tags": ["电影", "Emby", "TMDB", "推荐", "媒体库"],
  "category": "娱乐",
  "requirements": {
    "env": [
      "TMDB_API_KEY",
      "EMBY_URL",
      "EMBY_API_KEY",
      "EMBY_USER_ID"
    ]
  },
  "features": [
    "🌐 双源查询（TMDB + Emby）",
    "🔗 一键播放链接",
    "📊 精确年份匹配",
    "🎯 智能推荐算法",
    "👨‍👩‍👦 家庭电影之夜",
    "📈 观影统计报告",
    "💭 背景感知推荐",
    "🎬 演员/导演专题",
    "📺 Emby 观看历史同步",
    "🆕 新片提醒"
  ],
  "usage": {
    "examples": [
      "查询《复仇者联盟》",
      "推荐 10 部科幻电影",
      "李连杰的所有作品",
      "本周推荐什么电影？",
      "家庭电影之夜推荐",
      "观影统计报告"
    ]
  },
  "changelog": {
    "1.0.0": [
      "初始版本",
      "支持 TMDB 电影查询",
      "支持 Emby 媒体库集成",
      "支持一键播放链接",
      "支持批量推荐",
      "支持演员/导演专题",
      "支持观影记录与统计",
      "支持每周推荐",
      "支持家庭电影之夜",
      "支持背景感知推荐"
    ]
  }
}
