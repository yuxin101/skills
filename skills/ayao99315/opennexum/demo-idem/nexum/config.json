    },
    "codex-1": {
      "cli": "codex",
      "model": "gpt-5.4",
      "reasoning": "high"
    },
    "codex-frontend": {
      "cli": "codex",
      "model": "gpt-5.4",
      "reasoning": "medium"
    },
    "cc-frontend": {
      "cli": "claude",
      "model": "claude-sonnet-4-6"
    },
    "cc-writer": {
      "cli": "claude",
      "model": "claude-sonnet-4-6"
    },
    "eval": {
      "cli": "codex",
      "model": "gpt-5.4",
      "reasoning": "high"
    },
    "gardener": {
      "cli": "claude",
      "model": "claude-sonnet-4-6"
    }
