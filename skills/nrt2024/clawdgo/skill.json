{
  "name": "clawdgo",
  "version": "1.1.0",
  "description": "ClawdGo 龙虾网安训练营：AI Agent 安全意识训练，三层十二维度，七种训练模式，红蓝对抗竞技场，安全口诀系统，跨会话记忆持久化。",
  "category": "security-training",
  "license": "MIT-0",
  "author": "ClawdGo Team",
  "files": {
    "skill": "SKILL.md"
  },
  "requires": {
    "env": [],
    "bins": []
  },
  "sideEffects": {
    "fileWrites": [
      {
        "path": "soul.md",
        "scope": "openclaw-workspace",
        "description": "训练档案和安全口诀写入 soul.md（用户主动触发后执行，仅追加/更新 [ClawdGo ...] 标记区域，不修改其他内容）"
      },
      {
        "path": "~/.openclaw/clawdgo-arena-{room_id}.json",
        "scope": "user-home",
        "description": "Arena 双实例对抗模式（v1.1.0-beta，可选功能）：两只独立龙虾通过此文件共享对战状态，仅在用户主动传入 --room 参数时创建",
        "optional": true
      }
    ],
    "autonomousModes": [
      {
        "mode": "B self-train",
        "description": "自主训练：连续完成全部场景，期间无需用户确认。开场会明确告知用户，用户随时可发送"暂停"/"退出"中断。"
      },
      {
        "mode": "F arena",
        "description": "对抗竞技场：5 轮连续运行，期间无需用户确认。用户随时可发送"暂停"/"退出"中断。"
      }
    ],
    "cronNote": "SKILL.md 包含 cron 配置示例，仅供参考，Skill 本身不会自动安装任何定时任务。需用户在 OpenClaw 设置中手动配置。"
  },
  "capabilities": [
    "guided-training",
    "self-training",
    "exam-mode",
    "teach-mode",
    "evolve-mode",
    "arena-mode",
    "chant-mode",
    "soul-md-memory",
    "multi-role-roleplay",
    "red-blue-adversarial",
    "dual-instance-protocol",
    "12-dimension-scoring"
  ],
  "triggers": [
    "clawdgo",
    "开始训练",
    "网安训练",
    "龙虾训练",
    "clawdgo train",
    "clawdgo self-train",
    "自主训练",
    "clawdgo exam",
    "clawdgo teach",
    "教教我",
    "clawdgo evolve",
    "进化训练",
    "clawdgo arena",
    "对抗训练",
    "红蓝对抗",
    "clawdgo chant",
    "安全口诀",
    "口诀",
    "clawdgo memory",
    "clawdgo reset",
    "clawdgo version"
  ],
  "keywords": [
    "security",
    "phishing",
    "social-engineering",
    "training",
    "red-team",
    "blue-team",
    "adversarial",
    "mnemonic",
    "openclaw",
    "clawhub",
    "qclaw",
    "autoglm-claw"
  ]
}
