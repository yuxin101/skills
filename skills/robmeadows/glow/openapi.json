        "/api/v1/webhooks": {
            "post": {
                "summary": "Register webhook",
                "description": "Register a callback URL to receive real-time event notifications. Response includes an HMAC secret (shown once) for verifying signatures.",
                "security": [
                    {
                        "bearerAuth": []
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "required": [
                                    "url",
                                    "events"
                                ],
                                "properties": {
                                    "url": {
                                        "type": "string",
                                        "format": "uri",
                                        "description": "Callback URL"
                                    },
                                    "events": {
                                        "type": "array",
                                        "items": {
