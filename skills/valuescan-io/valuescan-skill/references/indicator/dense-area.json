{
  "name": "压力支撑位",
  "endpoint": "POST /indicator/getDenseAreaList",
  "description": "获取AI通过多数据维度，动态生成代币的智能压力位与支撑位的价格数据",
  "credits_cost": 1,
  "needToken": true,
  "use_case": "适用于对代币关键价格位置获取，适用于辅助判断压力和支撑位，适用于支撑交易决策判断",
  "params": {
    "vsTokenId": { "type": "long", "req": false, "desc": "代币ID" },
    "startTime": { "type": "long", "req": false, "desc": "开始时间（毫秒时间戳）" },
    "endTime": { "type": "long", "req": false, "desc": "结束时间（毫秒时间戳）" }
  },
  "response": {
    "vsTokenId": { "type": "long", "actualType": "string", "desc": "代币ID" },
    "symbol": { "type": "string", "actualType": "string", "desc": "代币符号" },
    "name": { "type": "string", "actualType": "string", "desc": "代币名称" },
    "date": { "type": "long", "actualType": "long", "desc": "时间（毫秒时间戳）" },
    "price": { "type": "number", "actualType": "string", "desc": "关键位价格" }
  },
  "example": {
    "req": { "vsTokenId": 1, "startTime": 1770825600000, "endTime": 1773417600000 },
    "res": {
      "code": 200,
      "data": [
        { "vsTokenId": "1", "symbol": "BTC", "name": "Bitcoin", "date": 1771059600000, "price": "69733.39" }
      ]
    }
  }
}
