{
  "name": "K 线数据",
  "endpoint": "POST /trade/kline/getTradeKLineList",
  "description": "获取K线数据，可查询指定代币（仅支持USDT交易对）和指定时间段内不超过1000条的K线数据",
  "credits_cost": 1,
  "needToken": true,
  "use_case": "适用于查询不同时间窗口类型的K线数据查询，适用于结合价格K线判断买卖时机",
  "update_frequency": "根据bucketType实时更新",
  "params": {
    "vsTokenId": { "type": "long", "req": true, "desc": "代币ID" },
    "bucketType": { "type": "string", "req": true, "desc": "K线时间窗口类型(5m/15m/30m/1h/4h/1d/1w)" },
    "startTime": { "type": "long", "req": false, "desc": "开始时间（毫秒时间戳）" },
    "endTime": { "type": "long", "req": true, "desc": "结束时间（毫秒时间戳）" },
    "size": { "type": "integer", "req": false, "desc": "查询记录数，默认360条，最大不超过1000条" }
  },
  "response": {
    "vsTokenId": { "type": "long", "actualType": "string", "desc": "代币ID" },
    "symbol": { "type": "string", "actualType": "string", "desc": "代币符号" },
    "name": { "type": "string", "actualType": "string", "desc": "代币名称" },
    "klineType": { "type": "string", "actualType": "string", "desc": "K线类型" },
    "klineData": {
      "type": "array",
      "desc": "K线数据",
      "item": {
        "time": { "type": "long", "actualType": "long", "desc": "时间（毫秒时间戳）" },
        "open": { "type": "number", "actualType": "string", "desc": "开盘价" },
        "close": { "type": "number", "actualType": "string", "desc": "收盘价" },
        "high": { "type": "number", "actualType": "string", "desc": "最高价" },
        "low": { "type": "number", "actualType": "string", "desc": "最低价" },
        "volume": { "type": "number", "actualType": "string", "desc": "成交量" },
        "amount": { "type": "number", "actualType": "string", "desc": "成交额(USD)" }
      }
    }
  },
  "enums": {
    "bucketType": {
      "5m": "5分钟",
      "15m": "15分钟",
      "30m": "30分钟",
      "1h": "1小时",
      "4h": "4小时",
      "1d": "1天",
      "1w": "1周"
    }
  },
  "example": {
    "req": { "vsTokenId": 1, "bucketType": "5m", "endTime": 1773478632535, "size": 20 },
    "res": {
      "code": 200,
      "data": {
        "vsTokenId": "1",
        "symbol": "BTC",
        "name": "Bitcoin",
        "klineType": "01",
        "klineData": [
          { "time": 1773478200000, "open": "70544.92", "close": "70594.48", "high": "70594.49", "low": "70536.58", "volume": "20.54", "amount": "1449509.94" }
        ]
      }
    }
  }
}
