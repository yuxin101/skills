{
  "name": "机会代币列表",
  "endpoint": "POST /ai/getChanceCoinList",
  "description": "获取AI通过多维度数据，追踪当前行情下具有上涨潜力的代币列表",
  "credits_cost": 3,
  "needToken": false,
  "use_case": "适用于当前行情下存在上涨行情机会的代币筛选和查询，适用于中短线交易者寻找具有上涨潜力的代币标的，适用于趋势跟踪策略中识别潜在上涨机会",
  "update_frequency": "每 5 分钟更新一次",
  "typeNote": "部分数值字段实际返回为字符串类型，使用时请注意类型转换",
  "params": {},
  "response": {
    "vsTokenId": { "type": "long", "actualType": "string", "desc": "代币ID" },
    "symbol": { "type": "string", "actualType": "string", "desc": "币种符号" },
    "price": { "type": "number", "actualType": "string", "desc": "当前价格(USD)" },
    "maxPrice": { "type": "number", "actualType": "string", "desc": "历史最高价格(USD)" },
    "minPrice": { "type": "number", "actualType": "string", "desc": "历史最低价格(USD)" },
    "percentChange1h": { "type": "number", "actualType": "string", "desc": "1小时价格变化百分比" },
    "percentChange24h": { "type": "number", "actualType": "string", "desc": "24小时价格变化百分比" },
    "percentChange7d": { "type": "number", "actualType": "string", "desc": "7天价格变化百分比" },
    "percentChange30d": { "type": "number", "actualType": "string", "desc": "30天价格变化百分比" },
    "percentChange60d": { "type": "number", "actualType": "string", "desc": "60天价格变化百分比" },
    "percentChange90d": { "type": "number", "actualType": "string", "desc": "90天价格变化百分比" },
    "cost": { "type": "number", "actualType": "string", "desc": "主力成本价格(USD)" },
    "costChange": { "type": "number", "actualType": "string", "desc": "成本变化率" },
    "deviation": { "type": "number", "actualType": "string", "desc": "价格偏离度(%)" },
    "marketCap": { "type": "number", "actualType": "string", "desc": "市值(USD)" },
    "marketCapRanking": { "type": "integer", "actualType": "integer", "desc": "市值排名" },
    "circulatingSupply": { "type": "number", "actualType": "string", "desc": "流通供应量" },
    "circulationRate": { "type": "number", "actualType": "string", "desc": "流通率(%)" },
    "active": { "type": "integer", "actualType": "string", "desc": "24h活跃地址数" },
    "newly": { "type": "integer", "actualType": "string", "desc": "24h新增地址数" },
    "tradeType": { "type": "integer", "actualType": "integer", "desc": "交易类型（1:现货 2:合约 3:交割合约）" },
    "chanceCoinTradeDataV1Vos": {
      "type": "array",
      "desc": "交易时间数据列表",
      "item": {
        "timeRange": { "type": "string", "actualType": "string", "desc": "时间范围标识（如m15, H4）" },
        "timeParticleEnum": { "type": "integer", "actualType": "integer", "desc": "时间粒度枚举值" },
        "tradeInflow": { "type": "number", "actualType": "string", "desc": "交易净流入金额(USD)" },
        "tradeAmount": { "type": "number", "actualType": "string", "desc": "交易总金额(USD)" }
      }
    },
    "updateTime": { "type": "long", "actualType": "long", "desc": "更新时间（毫秒时间戳）" },
    "pushPrice": { "type": "number", "actualType": "string", "desc": "入场推送价格(USD)" },
    "pushMaxPrice": { "type": "number", "actualType": "string", "desc": "推送后最高价(USD)" },
    "gains": { "type": "number", "actualType": "number", "desc": "推送后涨幅(%)" },
    "pushMinPrice": { "type": "number", "actualType": "string", "desc": "推送后最低价(USD)" },
    "declines": { "type": "number", "actualType": "number", "desc": "推送后跌幅(%)" },
    "score": { "type": "number", "actualType": "number", "desc": "AI综合评分" },
    "scoreChange": { "type": "number", "actualType": "number", "desc": "评分变化" },
    "grade": { "type": "integer", "actualType": "integer", "desc": "机会等级(1-3, 3为最高)" },
    "alpha": { "type": "boolean", "actualType": "boolean", "desc": "是否Alpha信号" },
    "fomo": { "type": "boolean", "actualType": "boolean", "desc": "是否FOMO状态" },
    "fomoEscalation": { "type": "boolean", "actualType": "boolean", "desc": "是否FOMO加剧" },
    "bullishRatio": { "type": "number", "actualType": "number", "desc": "看涨情绪比例" },
    "bearishRatio": { "type": "number", "actualType": "number", "desc": "看跌情绪比例" }
  },
  "field_meta": {
    "cost": { "meaning": "主力成本价格", "range": "根据大额交易加权计算的主力持仓成本", "advice": "当前价格低于成本价时可能是买入机会" },
    "deviation": { "meaning": "价格偏离度", "range": "(当前价格 - 主力成本) / 主力成本 * 100%", "advice": "负值表示低于成本，正值表示高于成本" },
    "score": { "meaning": "AI综合评分", "range": "0-100，基于资金流、技术指标等综合计算", "advice": "评分<=45或>=80：待观察代币；45<评分<55：观察代币；55<评分<80：机会代币" },
    "grade": { "meaning": "机会等级", "range": "1-3，3为最高等级", "advice": "等级越高表示风险越高" },
    "pushPrice": { "meaning": "入场推送价格", "range": "系统首次推送该机会代币时的价格", "advice": "用于计算入场后的涨跌幅" },
    "gains": { "meaning": "推送后涨幅", "range": "(pushMaxPrice - pushPrice) / pushPrice * 100%", "advice": "推送后的最大涨幅" },
    "declines": { "meaning": "推送后跌幅", "range": "(pushPrice - pushMinPrice) / pushPrice * 100%", "advice": "推送后的最大跌幅" },
    "alpha": { "meaning": "Alpha信号", "range": "布尔值，表示是否具有超额收益潜力", "advice": "true时关注度应更高" },
    "fomo": { "meaning": "FOMO信号", "range": "布尔值，表示市场情绪是否过热", "advice": "true时需警惕追高风险" },
    "fomoEscalation": { "meaning": "FOMO加剧", "range": "布尔值，FOMO状态进一步升级", "advice": "true时风险显著增加" },
    "active": { "meaning": "24h活跃地址数", "range": "过去24小时内有交易的链上地址数量", "advice": "反映市场参与热度" },
    "newly": { "meaning": "24h新增地址数", "range": "过去24小时内首次持有该代币的地址数量", "advice": "反映新资金流入" },
    "bullishRatio": { "meaning": "看涨情绪比例", "range": "0-1，基于社媒分析", "advice": "越接近1表示市场越看涨" },
    "bearishRatio": { "meaning": "看跌情绪比例", "range": "0-1，基于社媒分析", "advice": "越接近1表示市场越看跌" },
    "tradeInflow": { "meaning": "交易净流入", "range": "正值为资金流入，负值为资金流出", "advice": "持续正值表示主力在吸筹" }
  },
  "enums": {
    "tradeType": { "1": "现货", "2": "合约（永续）", "3": "交割合约" },
    "timeParticleEnum": { "5": "5分钟", "15": "15分钟", "30": "30分钟", "101": "1小时", "104": "4小时", "124": "24小时", "201": "1天", "207": "7天", "230": "30天" }
  },
