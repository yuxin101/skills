{
  "name": "盈亏趋势",
  "endpoint": "POST /chain/trade/token/profitLossTrend",
  "description": "获取指定地址在区块链上对某个代币的盈利或亏损的统计数据，支持通过指定代币、指定链名、指定时间段查询该地址的盈利或亏损数据",
  "credits_cost": 1,
  "needToken": true,
  "needCoinKey": true,
  "needAddress": true,
  "use_case": "适用于追踪特定地址的盈亏状况，适用于评估地址的投资绩效，适用于大户盈亏分析和市场情绪判断",
  "update_frequency": "每日更新",
  "params": {
    "vsTokenId": { "type": "long", "req": true, "desc": "代币ID" },
    "coinKey": { "type": "string", "req": true, "desc": "代币的coinKey（链+合约地址），通过代币详情获取" },
    "address": { "type": "string", "req": true, "desc": "地址" },
    "startTime": { "type": "long", "req": false, "desc": "开始时间（毫秒时间戳）" },
    "endTime": { "type": "long", "req": true, "desc": "截止时间（毫秒时间戳）" }
  },
  "response": {
    "vsTokenId": { "type": "long", "actualType": "string", "desc": "代币ID" },
    "symbol": { "type": "string", "actualType": "string", "desc": "代币符号" },
    "name": { "type": "string", "actualType": "string", "desc": "代币名称" },
    "date": { "type": "long", "actualType": "long", "desc": "时间（毫秒时间戳）" },
    "total": { "type": "number", "actualType": "string", "desc": "累计盈亏" },
    "day": { "type": "number", "actualType": "string", "desc": "每日盈亏" },
    "price": { "type": "number", "actualType": "string", "desc": "币价" }
  },
  "example": {
    "req": { "vsTokenId": 1, "coinKey": "BTC_BTC", "address": "3M219KR5vEneNb47ewrPfWyb5jQ2DjxRP6", "endTime": 1773479265534 },
    "res": {
      "code": 200,
      "data": [
        { "vsTokenId": "1", "symbol": "BTC", "name": "Bitcoin", "date": 1542038400000, "total": "0", "day": "0", "price": "6359.49" }
      ]
    }
  }
}
