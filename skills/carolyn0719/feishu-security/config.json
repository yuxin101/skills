{
  "version": "2.1.0",
  "owner": {
    "lark_id": "",
    "identified_at": null,
    "identified_by": null
  },
  "security": {
    "state": "UNBOUND",
    "locked": false,
    "auto_identify_sources": [
      "openclaw_config",
      "env_var",
      "feishu_api"
    ],
    "transfer": {
      "pending": false,
      "new_owner_id": null,
      "authorized_at": null,
      "expires_at": null
    }
  },
  "skill_install": {
    "require_approval": true,
    "approval_timeout_minutes": 10,
    "pending_requests": {},
    "trusted_sources": ["clawhub", "skillhub"],
    "blocked_skills": []
  },
  "rate_limits": {
    "user_same_content": {
      "count": 3,
      "window_seconds": 120,
      "penalty_seconds": 60
    },
    "user_total": {
      "count": 20,
      "window_seconds": 60,
      "penalty_seconds": 60
    }
  },
  "forbidden_paths": [
    "~/.ssh/",
    "~/.gnupg/",
    "~/.aws/",
    "~/.openclaw/credentials/",
    "/etc/passwd",
    "/etc/shadow",
    "/proc/self/environ",
    "/proc/self/cmdline",
    "/var/log/",
    "**/*key*",
    "**/*secret*",
    "**/*password*",
    "**/*token*",
    "**/*credential*",
    "*.pem",
    "*.p12",
    "*.pfx",
    "*.env",
    ".env.*"
  ],
