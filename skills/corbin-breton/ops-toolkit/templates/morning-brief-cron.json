{
  "name": "morning-brief",
  "schedule": "0 8 * * *",
  "timezone": "{{TIMEZONE}}",
  "agent_id": "{{AGENT_ID}}",
  "description": "Morning brief: summarize hot/warm facts and deliver to user via preferred channel",
  "command": "openclaw brief --agent {{AGENT_ID}} --base-path {{MEMORY_PATH}} --model {{MODEL}} --delivery {{DELIVERY_CHANNEL}} --target {{DELIVERY_TARGET}}",
  "model": "{{MODEL}}",
  "memory_path": "{{MEMORY_PATH}}",
  "knowledge_graph_path": "{{KNOWLEDGE_GRAPH_PATH}}",
  "delivery_channel": "{{DELIVERY_CHANNEL}}",
  "delivery_target": "{{DELIVERY_TARGET}}",
  "enabled": true,
  "retry_on_failure": true,
  "max_retries": 1,
  "timeout_seconds": 300,
  "log_output": true,
  "log_path": "logs/morning-brief.log",
  "notify_on_failure": true,
  "notification_channel": "{{NOTIFICATION_CHANNEL}}",
  "include_sections": {
    "hot_facts": true,
    "warm_facts": true,
    "risks": true,
    "priorities": true,
    "upcoming_events": false
  },
  "brief_format": "concise",
  "max_facts": 10,
  "max_words": 500,
  "env_vars": {
    "AGENT_NAME": "{{AGENT_NAME}}",
    "TIMEZONE": "{{TIMEZONE}}",
    "BRIEF_STYLE": "executive-summary"
  }
}
