{
  "name": "nightly-extraction",
  "schedule": "0 23 * * *",
  "timezone": "{{TIMEZONE}}",
  "agent_id": "{{AGENT_ID}}",
  "description": "Nightly memory extraction: parse daily notes and extract atomic facts into items.json",
  "command": "openclaw extract --agent {{AGENT_ID}} --base-path {{MEMORY_PATH}} --output-path {{OUTPUT_PATH}} --model {{MODEL}}",
  "model": "{{MODEL}}",
  "memory_path": "{{MEMORY_PATH}}",
  "output_path": "{{OUTPUT_PATH}}",
  "enabled": true,
  "retry_on_failure": true,
  "max_retries": 2,
  "timeout_seconds": 600,
  "log_output": true,
  "log_path": "logs/nightly-extraction.log",
  "notify_on_failure": false,
  "notification_channel": null,
  "pre_check": "test -d {{MEMORY_PATH}} && test -f {{MEMORY_PATH}}/YYYY-MM-DD.md",
  "post_action": "git -C {{WORKSPACE_ROOT}} add {{MEMORY_PATH}}/*/items.json && git -C {{WORKSPACE_ROOT}} commit -m 'nightly extraction: extracted facts'",
  "env_vars": {
    "AGENT_NAME": "{{AGENT_NAME}}",
    "MEMORY_FORMAT": "atomic-facts",
    "SUMMARY_REWRITE": "false"
  }
}
