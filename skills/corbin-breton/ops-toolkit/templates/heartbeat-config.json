{
  "managed_sessions": [
    {
      "name": "{{SESSION_NAME}}",
      "cwd": "{{SESSION_CWD}}",
      "prd": "{{SESSION_PRD_PATH}}"
    }
  ],
  "state_file": "heartbeat-state.json",
  "check_interval_minutes": 30,
  "auto_restart_on_stall": true,
  "stall_threshold": 2,
  "log_file": "logs/heartbeat.log",
  "log_level": "info",
  "notifications": {
    "enabled": false,
    "channel": "{{NOTIFICATION_CHANNEL}}",
    "on_stall": true,
    "on_restart": true,
    "on_missing": true
  },
  "metadata": {
    "agent_name": "{{AGENT_NAME}}",
    "workspace_root": "{{WORKSPACE_ROOT}}",
    "created_date": "{{CREATION_DATE}}",
    "purpose": "Monitor long-running tmux sessions for OpenClaw agent loops"
  }
}
