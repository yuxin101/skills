    {
      "parameters": {
        "jsCode": "const post = $('Determine Platforms').first().json;\nlet results;\n\n// Get results from LinkedIn branch if it ran\ntry {\n  results = { ...$('Record LinkedIn Result').first().json.results };\n} catch(e) {\n  results = { ...post.results };\n}\n\n// Record Substack result\ntry {\n  const emailResult = $('Email for Substack').first().json;\n  results.substack_status = 'published';\n} catch(e) {\n  // Substack was skipped or failed\n  if (post.do_substack) {\n    results.substack_status = 'failed';\n    results.notes = results.notes || [];\n    results.notes.push('Substack: email send failed');\n  }\n}\n\nconst notes = results.notes || [];\nconst has_failures = notes.length > 0;\n\nreturn [{\n  json: {\n    slug: post.slug,\n    title: post.title,\n    date: post.date,\n    canonical_url: post.canonical_url,\n    crossposted_at: new Date().toISOString().split('T')[0],\n    medium_status: results.medium_status || 'skipped',\n    medium_url: results.medium_url || '',\n    linkedin_status: results.linkedin_status || 'skipped',\n    linkedin_url: results.linkedin_url || '',\n    pinterest_status: results.pinterest_status || 'skipped',\n    pinterest_url: results.pinterest_url || '',\n    substack_status: results.substack_status || 'skipped',\n    notes: notes.join('; '),\n    has_failures: has_failures\n  }\n}];"
      },
