      "id": "a2",
      "name": "Fetch Post",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        -1168,
        304
      ]
    },
    {
      "parameters": {
        "jsCode": "const webhook = $('Webhook').first().json;\nconst post = $input.first().json;\n\nif (!post || !post.slug) {\n  throw new Error('Post not found: ' + (webhook.body?.slug || 'unknown'));\n}\nif (post.frontmatter?.draft === true) {\n  throw new Error('Skipping draft post: ' + post.slug);\n}\n\nconst canonical = 'https://YOUR_BLOG_DOMAIN/posts/' + post.slug + '/';\nlet imageUrl = '';\nif (post.frontmatter?.image) {\n  imageUrl = post.frontmatter.image.startsWith('http') ? post.frontmatter.image : 'https://YOUR_BLOG_DOMAIN' + post.frontmatter.image;\n}\n\nconst platformsRaw = webhook.body?.platforms || 'all';\nconst allPlatforms = ['medium', 'linkedin', 'pinterest', 'substack'];\nlet platforms = platformsRaw === 'all' ? allPlatforms : platformsRaw.split(',').map(p => p.trim().toLowerCase());\nconst tags = (post.frontmatter?.tags || []).slice(0, 5);\n\nreturn [{\n  json: {\n    slug: post.slug,\n    lang: post.lang || 'en',\n    title: post.frontmatter?.title || post.slug,\n    description: post.frontmatter?.description || '',\n    date: post.frontmatter?.date || '',\n    categories: post.frontmatter?.categories || [],\n    tags: tags,\n    body: post.body,\n    canonical_url: canonical,\n    image_url: imageUrl,\n    platforms: platforms,\n    platforms_str: platforms.join(',')\n  }\n}];"
      },
      "id": "a3",
      "name": "Validate Post",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -928,
        304
      ]
    },
    {
      "parameters": {
