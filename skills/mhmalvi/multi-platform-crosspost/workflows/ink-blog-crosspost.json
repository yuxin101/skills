    {
      "parameters": {
        "url": "=http://YOUR_BLOG_ADMIN_HOST:3000/api/posts/{{ $json.body.slug }}?lang={{ $json.body.lang || 'en' }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
