    {
      "parameters": {
        "fromEmail": "YOUR_FROM_EMAIL",
        "toEmail": "YOUR_NOTIFICATION_EMAIL",
        "subject": "=[Substack Ready] {{ $('Determine Platforms').first().json.title }}",
        "html": "=<h2>Ready to paste into Substack</h2>\n<p><strong>Title:</strong> {{ $('Determine Platforms').first().json.title }}</p>\n<p><strong>Canonical URL:</strong> <a href=\"{{ $('Determine Platforms').first().json.canonical_url }}\">{{ $('Determine Platforms').first().json.canonical_url }}</a></p>\n<hr>\n<div style=\"font-family: Georgia, serif; max-width: 680px; line-height: 1.8;\">{{ $('Determine Platforms').first().json.body.replace(/\\n/g, '<br>') }}</div>\n<hr>\n<p><em>Copy the content above and paste it into your Substack editor. Set the canonical URL to: {{ $('Determine Platforms').first().json.canonical_url }}</em></p>",
        "options": {}
      },
      "id": "a13",
      "name": "Email for Substack",
      "type": "n8n-nodes-base.emailSend",
      "typeVersion": 2.1,
