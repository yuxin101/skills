    {
      "parameters": {
        "jsCode": "const post = $('Determine Platforms').first().json;\nconst results = { ...post.results };\n\ntry {\n  const liResult = $('Post to LinkedIn').first().json;\n  if (liResult?.error || liResult?.statusCode >= 400 || liResult?.serviceErrorCode) {\n    results.linkedin_status = 'failed';\n    results.notes.push('LinkedIn: ' + (liResult.message || liResult.error || 'API error'));\n  } else {\n    results.linkedin_status = 'published';\n    results.linkedin_url = liResult?.postUrl || liResult?.activity || '';\n  }\n} catch(e) {\n  results.linkedin_status = 'failed';\n  results.notes.push('LinkedIn: ' + String(e));\n}\n\nreturn [{ json: { ...post, results } }];"
      },
