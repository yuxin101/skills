      "id": "a4",
      "name": "Read Tracker Sheet",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.7,
      "position": [
        -688,
        304
      ],
      "credentials": {
        "googleSheetsOAuth2Api": {
          "id": "YOUR_GOOGLE_SHEETS_CREDENTIAL_ID",
          "name": "Google Sheets account"
        }
      },
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "jsCode": "const post = $('Validate Post').first().json;\nconst webhook = $('Webhook').first().json;\nconst sheetRows = $('Read Tracker Sheet').all().map(i => i.json);\nconst existing = sheetRows.find(r => r.slug === post.slug);\nconst forceRepost = webhook.body?.force === true;\n\nlet platformsToPost = [...post.platforms];\nlet skipped = [];\n\nif (existing && !forceRepost) {\n  ['medium', 'linkedin', 'pinterest', 'substack'].forEach(p => {\n    if (existing[p + '_status'] === 'published' && platformsToPost.includes(p)) {\n      platformsToPost = platformsToPost.filter(x => x !== p);\n      skipped.push(p + ' (already published)');\n    }\n  });\n}\n\nreturn [{\n  json: {\n    ...post,\n    platforms_to_post: platformsToPost,\n    skipped_platforms: skipped,\n    is_retry: !!existing,\n    existing_row: existing || null,\n    do_medium: platformsToPost.includes('medium'),\n    do_linkedin: platformsToPost.includes('linkedin'),\n    do_pinterest: platformsToPost.includes('pinterest'),\n    do_substack: platformsToPost.includes('substack'),\n    results: {\n      linkedin_status: existing?.linkedin_status || 'skipped',\n      linkedin_url: existing?.linkedin_url || '',\n      medium_status: existing?.medium_status || 'skipped',\n      medium_url: existing?.medium_url || '',\n      pinterest_status: existing?.pinterest_status || 'skipped',\n      pinterest_url: existing?.pinterest_url || '',\n      substack_status: existing?.substack_status || 'skipped',\n      notes: []\n    }\n  }\n}];"
      },
