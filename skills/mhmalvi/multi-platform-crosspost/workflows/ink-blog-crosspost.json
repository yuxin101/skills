      "id": "a7",
      "name": "IF LinkedIn",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [
        48,
        304
      ]
    },
    {
      "parameters": {
        "jsCode": "const post = $('Determine Platforms').first().json;\nconst title = post.title;\nconst desc = post.description;\nconst body = post.body || '';\nconst tags = post.tags || [];\n\nconst lines = body.split('\\n').filter(l => l.trim().length > 50 && !l.startsWith('#'));\nconst excerpt = lines.slice(0, 2).join(' ').substring(0, 300);\nconst hashtags = tags.slice(0, 5).map(t => '#' + t.replace(/[^a-zA-Z0-9]/g, '')).join(' ');\n\nconst linkedinText = title + '\\n\\n' + (desc || excerpt) + '\\n\\nRead the full article on my blog:\\n\\n' + hashtags;\n\nreturn [{ json: { ...post, linkedin_text: linkedinText } }];"
      },
      "id": "a8",
      "name": "Build LinkedIn Text",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
