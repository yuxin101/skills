{
  "skill": {
    "name": "wechat-md-publisher",
    "version": "0.6.1",
    "enabled": true,
    "autoInvoke": true
  },
  "commands": {
    "publish": {
      "script": "./scripts/publish.sh",
      "args": ["publish"],
      "description": "发布文章到微信公众号"
    },
    "draft": {
      "script": "./scripts/publish.sh",
      "args": ["draft"],
      "description": "创建微信公众号草稿"
    },
    "wrapper": {
      "script": "./scripts/publish.sh",
      "args": ["wrapper"],
      "description": "Wrapper 功能管理（文章开头/结尾固定图文）"
    },
    "list-drafts": {
      "script": "./scripts/publish.sh",
      "args": ["list-drafts"],
      "description": "列出所有草稿"
    },
    "list-published": {
      "script": "./scripts/publish.sh",
      "args": ["list-published"],
      "description": "列出已发布文章"
    },
    "themes": {
      "script": "./scripts/publish.sh",
      "args": ["themes"],
      "description": "列出可用主题"
    }
  },
  "environment": {
    "required": [
      "NODE_VERSION>=18.0.0"
    ],
    "optional": [
      "WECHAT_APP_ID",
      "WECHAT_APP_SECRET"
    ]
  },
  "dependencies": {
    "npm": [
      "wechat-md-publisher@0.6.3",
      "jsdom@^27.4.0",
      "form-data-encoder@^4.1.0",
      "formdata-node@^6.0.3"
    ]
  },
  "permissions": {
    "filesystem": {
      "read": ["*.md", "*.jpg", "*.png", "*.gif"],
      "write": ["~/.config/wechat-md-publisher-nodejs/"]
    },
    "network": {
      "domains": ["api.weixin.qq.com", "mp.weixin.qq.com"]
    }
  }
}
