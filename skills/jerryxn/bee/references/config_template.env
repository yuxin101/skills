# 抖音工作流配置模板
# 复制此文件并根据需要修改

# ============ 阿里云OSS配置（必需） ============
export ALIYUN_OSS_ACCESS_KEY_ID="your_access_key_id_here"
export ALIYUN_OSS_ACCESS_KEY_SECRET="your_access_key_secret_here"
export ALIYUN_OSS_ENDPOINT="https://oss-cn-beijing.aliyuncs.com"
export ALIYUN_OSS_BUCKET="your_bucket_name_here"

# ============ 飞书多维表格配置（可选） ============
# 如需自动插入表格，请配置以下两项
export FEISHU_BITABLE_APP_TOKEN="your_app_token_here"
export FEISHU_BITABLE_TABLE_ID="your_table_id_here"

# ============ 使用说明 ============
# 1. 修改上述配置值
# 2. 运行：source ~/.bashrc
# 3. 验证：python3 ~/.openclaw/workspace/skills/douyin-workflow/scripts/workflow.py

# ============ 获取配置值 ============
# 阿里云OSS：
#   - AccessKey: 阿里云控制台 → 访问控制 → AccessKey管理
#   - Bucket: OSS控制台 → Bucket列表
#   - Endpoint: Bucket详情页查看

# 飞书多维表格：
#   - App Token: 多维表格URL中的 base/ 后的字符串
#   - Table ID: 表格设置中查看

# ============ 安全配置建议 ============
# 方法1：临时配置（当前终端会话有效）
#   直接在本文件修改后运行 source config.env
#
# 方法2：永久配置（添加到 ~/.bashrc）
#   将上述 export 命令添加到 ~/.bashrc 文件末尾
#   然后运行 source ~/.bashrc
#
# 方法3：使用配置助手
#   bash ~/.openclaw/workspace/skills/douyin-workflow/scripts/setup_env.sh