{
  "$schema": "https://developer.microsoft.com/en-us/json-schemas/teams/v1.17/MicrosoftTeams.schema.json",
  "manifestVersion": "1.17",
  "version": "1.0.1",
  "id": "8cbe4777-69c7-4e5c-b25d-2938e9f30e3d",
  "developer": {
    "name": "Elvatis GmbH",
    "websiteUrl": "https://elvatis.com",
    "privacyUrl": "https://elvatis.com/#impressum",
    "termsOfUseUrl": "https://elvatis.com/#impressum"
  },
  "name": {
    "short": "Akido",
    "full": "Akido - Elvatis AI Assistant"
  },
  "description": {
