            {
              "title": "Status",
              "description": "Shows the current status of the assistant"
            }
          ]
        }
      ]
    }
  ],
  "permissions": ["identity", "messageTeamMembers"],
  "validDomains": ["elvatis.com", "teams-bot.elvatis.com", "shield.elvatis.com"]
