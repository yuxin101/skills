{
  "work_dir": "./video-dubbing-workspace",
  "voxcpm_dir": "./VoxCPM",
  "ffmpeg_path": "ffmpeg",
  "translate": {
    "api_url": "https://api.siliconflow.cn/v1/chat/completions",
    "api_key": "YOUR_API_KEY_HERE",
    "model": "tencent/Hunyuan-MT-7B"
  },
  "whisper": {
    "model": "medium",
    "language": "en"
  },
  "tts": {
    "reference_audio": "./reference_audio/speaker.wav",
    "reference_text": "你的参考音频对应的文本内容",
    "max_group_duration": 15.0,
    "inference_timesteps": 10,
    "cfg_value": 2.0
  },
  "subtitle": {
    "fontsize": 16,
    "fontname": "SimHei",
    "outline": 2,
    "margin_v": 20,
    "alignment": 2
  },
  "output": {
    "default_name": "dubbed",
    "video_codec": "h264_nvenc",
    "audio_codec": "aac"
  }
}