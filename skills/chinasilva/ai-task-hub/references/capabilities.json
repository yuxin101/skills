    {
      "id": "video-face-generation",
      "service_id": "svc_tencent_video_face_fusion",
      "summary": "Generate a video face result from an uploaded source video and face image.",
      "input_schema": {
        "type": "object",
        "required": [
          "video_url",
          "merge_infos"
        ],
        "properties": {
          "video_url": {
            "type": "string",
            "format": "uri",
            "description": "Upload a short source video through the host product flow. Video face generation requires both this video and merge_infos[0].merge_face_image.url before execution. Use controlled media storage URLs. Do not require manual URL or raw JSON input in user-facing forms."
          },
          "merge_infos": {
            "type": "array",
            "minItems": 1,
            "maxItems": 1,
            "items": {
              "type": "object",
              "required": [
                "merge_face_image"
              ],
              "properties": {
                "merge_face_image": {
                  "type": "object",
                  "required": [
                    "url"
                  ],
                  "properties": {
                    "url": {
                      "type": "string",
                      "format": "uri",
                      "description": "Upload a merge-face image through the host product flow. Video face generation requires both this image and video_url before execution. Use controlled media storage URLs. Do not require manual URL or raw JSON input in user-facing forms."
                    }
                  }
                }
              }
            }
          },
          "b_long_video": {
            "type": "boolean",
            "description": "Set true to use the long-video submission flow."
          },
          "project_id": {
            "type": "string",
            "description": "Optional legacy project id. Must be paired with model_id."
          },
          "model_id": {
            "type": "string",
            "description": "Optional legacy model id. Must be paired with project_id."
          }
        }
      },
      "example_input": {
        "video_url": "https://interactive-examples.mdn.mozilla.net/media/cc0-videos/flower.mp4",
        "merge_infos": [
          {
            "merge_face_image": {
              "url": "https://raw.githubusercontent.com/ultralytics/yolov5/master/data/images/zidane.jpg"
            }
          }
        ],
        "b_long_video": false
      }
    }
