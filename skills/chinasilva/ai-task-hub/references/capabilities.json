{
  "capabilities": [
    {
      "id": "human_detect",
      "service_id": "svc_cf_human_detect",
      "summary": "Detect human presence in an image.",
      "input_schema": {
        "type": "object",
        "required": [
          "image_url"
        ],
        "properties": {
          "image_url": {
            "type": "string",
            "format": "uri",
            "description": "Upload an image file/attachment through the host product flow. Use controlled media storage URLs. Do not require manual URL or raw JSON input in user-facing forms."
          }
        }
      },
      "example_input": {
        "image_url": "https://media.roboflow.com/inference/soccer.jpg"
      }
    },
    {
      "id": "image_tagging",
