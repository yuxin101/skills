      }
    },
    "/agent/skill/account/ledger": {
      "get": {
        "summary": "portal.account.ledger",
        "security": []
      }
    },
    "/agent/public-bridge/invoke": {
      "post": {
        "summary": "Preferred public bridge invoke endpoint",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "entry_host",
                  "action",
                  "agent_uid",
                  "conversation_id"
                ],
                "properties": {
                  "entry_host": {
                    "type": "string",
                    "pattern": "^[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?$",
                    "description": "Host runtime slug. Current built-in examples include openclaw, mobileclaw, codex, and claude; future lowercase host slugs can use the same contract."
                  },
                  "entry_user_key": {
                    "type": "string"
                  },
                    "action": {
                      "type": "string",
                      "enum": [
                        "portal.skill.execute",
                        "portal.skill.poll",
                        "portal.skill.presentation",
                        "portal.account.connect",
                        "portal.account.balance",
                        "portal.account.ledger"
                      ]
                    },
                  "agent_uid": {
                    "type": "string"
                  },
                  "conversation_id": {
                    "type": "string"
                  },
                  "payload": {
                    "type": "object",
                    "additionalProperties": true
                  },
                  "options": {
                    "type": "object",
                    "additionalProperties": true,
                    "properties": {
                      "expires_in_seconds": {
                        "type": "integer",
                        "minimum": 60,
                        "maximum": 900
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Bridge-invoked read/poll/presentation result; success data includes entry_host and entry_user_key"
          },
          "202": {
            "description": "Bridge-invoked execute accepted; success data includes entry_host and entry_user_key"
          },
          "400": {
            "description": "Invalid bridge request"
          },
          "401": {
            "description": "AUTHORIZATION_REQUIRED with authorization_url, entry_user_key, and possible recovery hints such as likely_cause=ENTRY_USER_KEY_NOT_REUSED"
          },
          "429": {
            "description": "Bootstrap rate limit exceeded"
          }
        }
      }
    },
    "/agent/hosted-connector/install": {
      "post": {
        "summary": "Create a hosted connector installation",
        "responses": {
          "200": {
            "description": "Hosted connector installation created; returns connection_id and connection_token"
          },
          "400": {
            "description": "Invalid hosted connector install request"
          }
        }
      }
    },
    "/agent/hosted-connector/connect": {
      "post": {
        "summary": "Start or resume hosted connector browser authorization",
        "parameters": [
          {
            "name": "x-connector-token",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Hosted connector authorization state; may return authorization_url, auth_session_id, and entry_user_key"
          },
          "401": {
            "description": "Missing or invalid connection token"
          }
        }
      }
    },
    "/agent/hosted-connector/invoke": {
      "post": {
        "summary": "Invoke a hosted connector action with installation-scoped continuity",
        "parameters": [
          {
            "name": "x-connector-token",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Hosted connector read/poll/presentation result; success data includes connection_id and connector_status"
          },
          "202": {
            "description": "Hosted connector execute accepted; success data includes connection_id and connector_status"
          },
          "401": {
            "description": "Missing or invalid connection token"
          }
        }
      }
    },
    "/agent/hosted-connector/status": {
      "post": {
        "summary": "Read hosted connector status for one installation",
        "parameters": [
          {
            "name": "x-connector-token",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Hosted connector status for the installation"
          },
          "401": {
            "description": "Missing or invalid connection token"
          }
        }
      }
    },
    "/agent/hosted-connector/logout": {
      "post": {
        "summary": "Clear hosted connector continuity for one installation",
        "parameters": [
          {
            "name": "x-connector-token",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Hosted connector continuity cleared for the installation"
          },
          "401": {
            "description": "Missing or invalid connection token"
          }
        }
      }
    },
    "/agent/skill/bridge/invoke": {
      "post": {
        "summary": "Trusted host bridge invoke endpoint"
      }
    }
  },
