  "x-host-auth-onboarding": {
    "type": "bridge_managed",
    "primary_entrypoint_endpoint": "/agent/public-bridge/invoke",
    "primary_entrypoint_first_time_error": {
      "code": "AUTHORIZATION_REQUIRED",
      "response_fields": [
        "authorization_url",
        "entry_user_key",
        "gateway_api_base_url",
        "auth_session_id",
        "retry_after_seconds"
      ],
      "notes": [
        "With TRIAL_ENABLED and available trial points, first-time calls may succeed without browser authorization.",
        "AUTHORIZATION_REQUIRED is expected when trial is exhausted, trial is disabled, or authorization upgrade is otherwise required."
      ]
    },
    "primary_entrypoint_first_time_success": {
      "response_fields": [
        "entry_host",
        "entry_user_key"
      ],
      "notes": [
        "On successful first-time trial responses, persist entry_user_key immediately.",
        "Reuse that same entry_user_key across follow-up calls to keep stable account continuity."
      ]
    },
    "agent_uid_format": "^agent_[a-z0-9][a-z0-9_-]{5,63}$",
    "conversation_id_format": "^[A-Za-z0-9._:-]{8,128}$"
  },
