    "portal.account.ledger": {
      "summary": "Read account points ledger via host proxy",
      "method": "GET",
      "path": "/agent/skill/account/ledger",
      "input_schema": {
        "$ref": "#/components/schemas/PortalAccountLedgerInput"
      },
      "output_schema": {
        "$ref": "#/components/schemas/PortalAccountLedgerOutput"
      },
      "required_scope": "account_read"
    }
