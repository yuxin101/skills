  "x-agent-invocation-guide": {
    "preferred_entrypoint": "public_bridge",
    "user_response_policy": {
      "attachment_requests": "Treat uploaded files as ready for execution, prefer attachment URLs, and when the host exposes explicit attachment bytes, forward that explicit material before returning results or progress.",
      "internal_mechanics_visibility": "Do not expose image_url, attachment.url, storage URLs, bridge layers, or upload normalization details to end users unless they explicitly ask for technical debugging.",
      "manual_url_requests": "Do not ask end users to provide manual URLs, JSON field names, or upload-chain instructions.",
      "failure_language": "If user intervention is required, describe only the minimal next step in user-oriented language without revealing internal layering."
    },
    "host_bridge_note": "Host bridge entrypoint is host-owned integration code and is not bundled in this published package.",
    "bridge_auth_guidance": {
      "continuity_owner": "host_or_private_wrapper",
      "published_skill_persistence": "disabled",
      "success_contract": {
        "location": "data.agent_guidance.bridge_auth",
        "bridge_context_fields": [
          "entry_host",
          "entry_user_key"
        ],
        "reuse_targets": [
          "/agent/public-bridge/invoke",
          "/agent/public-bridge/upload-file"
        ],
        "reuse_actions": [
          "portal.account.connect",
          "portal.account.balance",
          "portal.account.ledger",
          "portal.skill.execute",
          "portal.skill.poll",
          "portal.skill.presentation"
        ]
      },
      "error_contract": {
        "location": "error.details.bridge_auth",
        "bridge_context_fields": [
          "entry_host",
          "entry_user_key"
        ],
        "recovery_fields": [
          "likely_cause",
          "recovery_action",
          "reauthorization_required"
        ]
      }
    },
    "action_payload_templates": {
      "portal.skill.execute": {
        "capability": "human_detect",
        "input": {
          "image_url": "https://files.example.com/demo.png"
        },
        "request_id": "optional_request_id"
      },
      "portal.skill.poll": {
        "run_id": "run_123"
      },
      "portal.skill.presentation": {
        "run_id": "run_123",
        "channel": "web",
        "include_files": true
      },
      "portal.account.connect": {
        "connect_mode": "browser",
        "auth_session_id": "optional_existing_auth_session"
      },
      "portal.account.balance": {},
      "portal.account.ledger": {
        "date_from": "2026-03-01",
        "date_to": "2026-03-15"
      }
    },
    "error_handling": [
      {
        "match": {
          "code": "AUTHORIZATION_REQUIRED",
          "message_contains": "bridge authorization is required"
        },
        "host_action": "show authorization_url, persist entry_user_key, then retry same action after authorization"
      },
      {
        "match": {
          "code": "AUTHORIZATION_REQUIRED",
          "details": {
            "likely_cause": "ENTRY_USER_KEY_NOT_REUSED",
            "recovery_action": "REUSE_ENTRY_USER_KEY",
            "reauthorization_required": false
          }
        },
        "host_action": "restore the previously persisted entry_user_key and retry the same bridge call before asking the user to authorize again"
      },
      {
        "match": {
          "code": "AUTH_UNAUTHORIZED",
          "message_contains": "agent_uid claim format is invalid"
        },
        "host_action": "normalize host agent_uid and retry the same bridge call"
      },
      {
        "match": {
          "code": "SYSTEM_NOT_FOUND",
          "message_contains": "agent binding not found"
        },
        "host_action": "restart the same bridge flow once so gateway can repair binding"
      }
    ],
    "explicit_connect_action": {
      "action": "portal.account.connect",
      "request_body": {
        "connect_mode": "browser"
      },
      "when_to_use": "Use this explicit action when the user wants to bind/login/check account connection before balance, ledger, or execute actions.",
      "success_states": [
        "authorization_required",
        "pending",
        "connected"
      ]
    },
    "bridge_api": {
      "endpoint": "/agent/public-bridge/invoke",
      "method": "POST",
      "requires_caller_managed_task_token": false,
      "request_body": {
        "entry_host": "<host_runtime>",
        "action": "portal.account.balance",
        "agent_uid": "support_assistant",
        "conversation_id": "host_session_20260316_opaque_001",
        "payload": {}
      },
      "notes": [
        "Preferred production entrypoint for third-party agent-friendly integration.",
        "entry_host must match the active host runtime. Current built-in examples are mobileclaw, openclaw, codex, and claude; future lowercase host slugs can follow the same contract. If omitted, export PUBLIC_BRIDGE_ENTRY_HOST or AI_TASK_HUB_ENTRY_HOST so the packaged runtime does not fall back to the wrong host.",
        "Example mappings: MobileClaw -> mobileclaw, OpenClaw -> openclaw, Codex -> codex, Claude -> claude. For a future host, reuse the same lowercase host slug for host and entry_host unless you intentionally need a different mapping.",
        "For end-user conversations, prefer direct execution and result delivery instead of explaining attachment upload or URL normalization internals.",
        "When the host exposes attachment bytes, the published skill forwards only that explicit attachment material through the public bridge before execute and injects the returned URL into the target media field.",
        "published skill persistence = disabled; continuity owner = host_or_private_wrapper.",
        "agent_uid should be the host-defined stable runtime agent identifier; bridge canonicalizes it server-side.",
        "conversation_id should be a host-generated opaque session or install identifier, not a public chat id, raw thread id, or PII.",
        "When TRIAL_ENABLED and trial points are available, first-time onboarding can proceed without browser authorization.",
        "Public bridge should resolve a stable external user binding when available; for new installations with TRIAL_ENABLED and available trial points, onboarding proceeds without browser authorization, and AUTHORIZATION_REQUIRED is returned only for conditional upgrade paths (for example trial exhausted or trial disabled rollback).",
        "authorization_url may include gateway_api_base_url and hosts should preserve it when completing browser authorization so the binding write lands on the same API environment.",
        "Cross-conversation account continuity requires reusing the same entry_user_key across follow-up calls.",
        "Successful public bridge responses include entry_host and entry_user_key; persist and reuse them even when no authorization error is returned.",
        "Use portal.account.connect as the explicit user-invoked bind/check action instead of relying only on AUTHORIZATION_REQUIRED from other actions.",
        "If AUTHORIZATION_REQUIRED includes likely_cause=ENTRY_USER_KEY_NOT_REUSED and reauthorization_required=false, hosts should restore the previously persisted entry_user_key instead of launching a new browser login.",
        "Gateway canonicalizes agent_uid, repairs binding when missing, and issues action-scoped task token internally.",
        "Write-capable execute actions should send options.confirm_write=true after user confirmation; otherwise gateway may return ACTION_CONFIRMATION_REQUIRED.",
        "base_url, gateway_api_key, api_key, user_token, agent_task_token, owner_uid_hint, and install_channel overrides are rejected by this bridge endpoint."
      ]
    },
    "trusted_host_bridge_api": {
      "endpoint": "/agent/skill/bridge/invoke",
      "method": "POST",
      "requires_caller_managed_task_token": false
    }
  },
  "paths": {
    "/agent/skill/execute": {
      "post": {
        "summary": "portal.skill.execute",
        "security": []
      }
    },
    "/agent/skill/runs/{runId}": {
      "get": {
        "summary": "portal.skill.poll",
        "security": []
      }
    },
    "/agent/skill/runs/{runId}/presentation": {
      "get": {
        "summary": "portal.skill.presentation",
        "security": []
      }
