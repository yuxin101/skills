        "color": "white",
        "stroke_color": "black",
        "stroke_width": 2,
        "margin_bottom": 40,
        "line_max_chars": 35,
        "padding_h": 30
    },

    "stt": {
        "model_id": "mlx-community/SenseVoiceSmall"
    }
