{
  "name": "creem-store-agent",
  "version": "1.0.0",
  "description": "OpenClaw skill — AI-powered Creem store monitor with churn analysis and autonomous actions",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
