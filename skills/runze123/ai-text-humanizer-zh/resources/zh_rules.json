  "sentence_patterns": [
    {
      "pattern": "不仅(.*?)而且(.*?)",
      "rewrites": ["\\1并且\\2", "\\1，同时也\\2", "既\\1又\\2", "\\1，此外还\\2"]
    },
    {
      "pattern": "一方面(.*?)另一方面(.*?)",
      "rewrites": ["\\1；\\2", "\\1，同时\\2"]
    },
    {
      "pattern": "第一[,，](.*?)第二[,，](.*?)第三[,，](.*?)",
      "rewrites": ["\\1；\\2；\\3", "\\1。\\2。\\3"]
    },
    {
      "pattern": "既(.*?)又(.*?)",
      "rewrites": ["\\1，同时也\\2", "\\1而且\\2"]
    },
    {
      "pattern": "之所以(.*?)是因为(.*?)",
      "rewrites": ["\\1，这是因为\\2", "因为\\2，所以\\1"]
    },
    {
      "pattern": "如果(.*?)那么(.*?)",
      "rewrites": ["假如\\1，则\\2", "\\1时，\\2"]
    },
    {
      "pattern": "虽然(.*?)但是(.*?)",
      "rewrites": ["尽管\\1，但\\2", "\\1，然而\\2"]
    },
    {
      "pattern": "因为(.*?)所以(.*?)",
      "rewrites": ["由于\\1，因此\\2", "\\1导致\\2"]
    },
    {
      "pattern": "不仅(.*?)还(.*?)",
      "rewrites": ["\\1并且\\2", "\\1，同时\\2"]
    },
    {
      "pattern": "要么(.*?)要么(.*?)",
      "rewrites": ["\\1或者\\2", "\\1，或者\\2"]
    }
  ],
