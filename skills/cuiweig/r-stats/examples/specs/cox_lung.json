{
  "dataset_path": "examples/data/lung_cancer.csv",
  "analysis_type": "cox_regression",
  "time_var": "time",
  "event_var": "status",
  "predictors": ["age", "sex", "ph.ecog"],
  "formula": "Surv(time, status) ~ age + sex + ph.ecog",
  "hypothesis": "Age, sex, and ECOG performance score are associated with survival in lung cancer patients",
  "alpha": 0.05,
  "seed": 42,
  "output_dir": "output/cox_lung"
}
