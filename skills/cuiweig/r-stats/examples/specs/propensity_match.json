{
  "dataset_path": "examples/data/observational_treatment.csv",
  "analysis_type": "propensity_match",
  "treatment_var": "treated",
  "formula": "treated ~ age + female + comorbidity",
  "outcome_var": "outcome",
  "match_method": "nearest",
