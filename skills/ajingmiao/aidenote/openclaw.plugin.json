{
  "id": "slonaide",
  "name": "SlonAide",
  "version": "2.0.0",
  "description": "SlonAide 录音笔记管理插件",
  "main": "index.js",
  "configSchema": {
    "type": "object",
    "properties": {
      "apiKey": {
        "type": "string",
        "description": "SlonAide API Key (格式: sk-xxx...)",
        "secret": true
      },
      "baseUrl": {
        "type": "string",
        "description": "API 基础地址",
        "default": "https://api.aidenote.cn"
      }
    },
    "required": ["apiKey"]
  }
}